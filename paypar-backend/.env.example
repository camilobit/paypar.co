# ─────────────────────────────────────────
# PAYPAR BACKEND — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas .env al repositorio
# ─────────────────────────────────────────

# SERVIDOR
PORT=4000
NODE_ENV=development

# BASE DE DATOS (Supabase o local)
DATABASE_URL="postgresql://postgres:password@localhost:5432/paypar_db"

# JWT
JWT_SECRET=cambia_esto_por_un_string_largo_y_aleatorio_minimo_64_caracteres
JWT_EXPIRES_IN=7d

# FRONTEND (para CORS)
FRONTEND_URL=http://localhost:5173

# GOOGLE OAUTH (gratuito en console.cloud.google.com)
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# WOMPI (sandbox gratuito en wompi.co)
WOMPI_PUBLIC_KEY=pub_test_xxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxx
WOMPI_EVENTS_SECRET=tu_wompi_events_secret

# LOGS
LOG_LEVEL=debug
